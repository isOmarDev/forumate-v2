{
  "name": "dddforum",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "license": "ISC",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "start": "npm start -w @dddforum/backend",
    "build": "npm run build:shared && npm run build:back && npm run build:front",
    "build:shared": "npm run build -w @dddforum/shared",
    "build:front": "npm run build -w @dddforum/frontend",
    "build:back": "npm run build -w @dddforum/backend",
    "start:dev": "concurrently -n backend,frontend -c blue,green \"npm run start:dev -w @dddforum/backend\" \"npm run start:dev -w @dddforum/frontend\"",
    "start:dev:back": "npm run start:dev -w @dddforum/backend",
    "start:dev:front": "npm run start:dev -w @dddforum/frontend",
    "test:e2e:back": "npm run test:e2e -w @dddforum/backend",
    "test:e2e:front": "npm run test:e2e -w @dddforum/frontend",
    "test:infra:back": "npm run test:infra -w @dddforum/backend"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.53.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-cucumber": "^4.5.0",
    "prettier": "^2.7.1",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
