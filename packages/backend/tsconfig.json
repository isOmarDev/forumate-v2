{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["ES2022"],
    "types": ["node", "jest", "jest-cucumber", "@faker-js/faker"],

    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,

    "isolatedModules": true,
    "esModuleInterop": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  },
  "include": ["./src"],
  "exclude": ["**/*.spec.ts", "**/*.infra.ts", "**/*.test.ts", "**/*.e2e.ts"],
  "references": [{ "path": "../shared" }]
}
